#!/usr/bin/env bash

set -euo pipefail

# ── Configuration ─────────────────────────────────────────────────────────────

DEFAULT_IMAGE=""  # Set to a default image reference, e.g. "registry.example.com/myorg/myimage:latest"

CONTAINER_IMAGE=""
CUSTOM_CONTAINERFILE=""
CUSTOM_JSON=""

# ── Helpers ───────────────────────────────────────────────────────────────────

bold() { printf "\033[1m%s\033[0m\n" "$*"; }

print_help() {
    cat <<EOF
Usage: $0 [-h] [-i IMAGE] [-c CONTAINERFILE] [-j JSON]
Prepare a JetBrains development container.

This script can be executed from any location in a git repository.
JetBrains supports multiple devcontainers per project; each gets a
unique name derived from the image reference.

Options:
  -h, --help                Show this help page
  -i, --image IMAGE         Use IMAGE directly, skipping interactive selection
  -c, --containerfile FILE  Use FILE as the Dockerfile instead of the built-in default
  -j, --json FILE           Use FILE as devcontainer.json instead of the built-in default
EOF
}

# ── Image selection ───────────────────────────────────────────────────────────

select_image() {
    mapfile -t ALL_IMAGES < <(podman images --format "{{.Repository}}:{{.Tag}}")

    if [[ ${#ALL_IMAGES[@]} -eq 0 ]]; then
        echo "No images found. Please provide one with -i / --image."
        exit 1
    fi

    local matches=("${ALL_IMAGES[@]}")

    while true; do
        if [[ ${#matches[@]} -eq 1 ]]; then
            printf "\nSingle match: %s\nUse this image? [Y/n]: " "${matches[0]}"
            read -r confirm
            if [[ -z "$confirm" || "$confirm" =~ ^[Yy]$ ]]; then
                CONTAINER_IMAGE="${matches[0]}"
                return
            fi
            matches=("${ALL_IMAGES[@]}")  # declined — start over
        fi

        if [[ ${#matches[@]} -lt ${#ALL_IMAGES[@]} ]]; then
            printf "\n%d matches:\n" "${#matches[@]}"
            printf "  - %s\n" "${matches[@]}"
        fi

        local default_hint=""
        [[ -n "$DEFAULT_IMAGE" ]] && default_hint=" [Enter for default: $DEFAULT_IMAGE]"
        printf "\nFilter (regex/substring)%s: " "$default_hint"
        read -r term

        if [[ -z "$term" ]]; then
            if [[ -n "$DEFAULT_IMAGE" ]]; then
                echo "Using default image: $DEFAULT_IMAGE"
                CONTAINER_IMAGE="$DEFAULT_IMAGE"
                return
            fi
            echo "Filter cannot be empty. Please enter a search term."
            continue
        fi

        mapfile -t narrowed < <(printf "%s\n" "${matches[@]}" | grep -Ei -- "$term" || true)
        if [[ ${#narrowed[@]} -eq 0 ]]; then
            echo "No matches for '$term'. Try again."
            continue
        fi
        matches=("${narrowed[@]}")
    done
}

# ── Writers ───────────────────────────────────────────────────────────────────

CMAKE_OPTS="-DCMAKE_CXX_COMPILER_LAUNCHER=ccache -DENABLE_TESTING=ON -DCMAKE_POLICY_VERSION_MINIMUM=3.5"

write_cmake_xml() {
    # Write the default cmake.xml to .idea/ if not already present.
    [[ -f ".idea/cmake.xml" ]] && return
    cat > ".idea/cmake.xml" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<project version="4">
  <component name="CMakeSharedSettings">
    <configurations>
      <configuration PROFILE_NAME="Debug" ENABLED="true" CONFIG_NAME="Debug" GENERATION_OPTIONS="${CMAKE_OPTS}" />
      <configuration PROFILE_NAME="RelWithDebInfo" ENABLED="false" CONFIG_NAME="RelWithDebInfo" GENERATION_OPTIONS="${CMAKE_OPTS}" />
    </configurations>
  </component>
</project>
EOF
}

write_containerfile() {
    # Write a Dockerfile to the devcontainer directory.
    # Uses the custom file if provided, otherwise writes the built-in default.
    local dest=".devcontainer/${DEVCONTAINER_NAME}/Dockerfile"
    if [[ -n "$CUSTOM_CONTAINERFILE" ]]; then
        cp "$CUSTOM_CONTAINERFILE" "$dest"
        echo "Using custom Containerfile: $CUSTOM_CONTAINERFILE"
        return
    fi
    cat > "$dest" <<EOF
FROM $CONTAINER_IMAGE

RUN if ! command -v microdnf 2>&1 /dev/null && command -v dnf 2>&1 /dev/null; then \\
      dnf install -y microdnf; \\
    fi

RUN microdnf install --setopt=install_weak_deps=0 -y \\
  git git-lfs gdb gdb-gdbserver gcc-c++ perf js-d3-flame-graph strace valgrind socat \\
  curl unzip tar findutils grep xterm procps-ng firefox bash-completion \\
  libXtst libXrender libXext freetype libXi mesa-libgbm libdrm libicu \\
  && microdnf clean all \\
  && rm -rf /var/cache/dnf
EOF
}

write_devcontainer_json() {
    # Write devcontainer.json to the devcontainer directory.
    # Uses the custom file if provided, otherwise writes the built-in default.
    local dest=".devcontainer/${DEVCONTAINER_NAME}/devcontainer.json"
    if [[ -n "$CUSTOM_JSON" ]]; then
        cp "$CUSTOM_JSON" "$dest"
        echo "Using custom devcontainer.json: $CUSTOM_JSON"
        return
    fi
    cat > "$dest" <<EOF
{
    "name": "${DEVCONTAINER_NAME}",
    "build": {"dockerfile": "Dockerfile"},
    "capAdd": ["SYS_ADMIN", "SYS_PTRACE", "PERFMON"],
    "runArgs": ["--net=host", "--pid=host", "--ipc=host"],
    "privileged": true,
    "securityOpt": ["label=disable"],
    "mounts": [],
    "containerEnv": {},
    "workspaceMount": "src=\${localWorkspaceFolder},dst=\${localWorkspaceFolder},type=bind",
    "workspaceFolder": "\${localWorkspaceFolder}"
}
EOF
}

# ── Parse args ────────────────────────────────────────────────────────────────

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)          print_help; exit 0 ;;
        -i|--image)         CONTAINER_IMAGE="$2"; shift 2 ;;
        -c|--containerfile) CUSTOM_CONTAINERFILE="$2"; shift 2 ;;
        -j|--json)          CUSTOM_JSON="$2"; shift 2 ;;
        *)                  echo "Unknown option: $1"; exit 1 ;;
    esac
done

# ── Validate custom file paths ────────────────────────────────────────────────

if [[ -n "$CUSTOM_CONTAINERFILE" && ! -f "$CUSTOM_CONTAINERFILE" ]]; then
    echo "Error: Containerfile not found: $CUSTOM_CONTAINERFILE"
    exit 1
fi

if [[ -n "$CUSTOM_JSON" && ! -f "$CUSTOM_JSON" ]]; then
    echo "Error: devcontainer.json not found: $CUSTOM_JSON"
    exit 1
fi

# ── Resolve repo root ─────────────────────────────────────────────────────────

if git rev-parse --is-inside-work-tree &>/dev/null; then
    cd "$(git rev-parse --show-toplevel)"
else
    echo "[!] Not inside a git repository — .devcontainer will be created in $PWD"
fi

# ── Select image ──────────────────────────────────────────────────────────────

[[ -z "$CONTAINER_IMAGE" ]] && select_image

# ── Derive name and scaffold ──────────────────────────────────────────────────

DEVCONTAINER_NAME=$(awk -F'[/:]' '{print $(NF-1)"_"$NF}' <<< "$CONTAINER_IMAGE")

bold "Setting up a JetBrains devcontainer:"
bold "  - name:  ${DEVCONTAINER_NAME}"
bold "  - image: ${CONTAINER_IMAGE}"

mkdir -p ".idea" ".devcontainer/${DEVCONTAINER_NAME}"

write_cmake_xml
write_containerfile
write_devcontainer_json

echo ""
bold "[+] ${PWD}/.devcontainer/${DEVCONTAINER_NAME}/devcontainer.json"
